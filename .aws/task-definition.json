{
    "family": "dc-dashboard-task",
    "networkMode": "awsvpc",
    "executionRoleArn": "arn:aws:iam::019163347606:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "dc-dashboard",
            "image": "019163347606.dkr.ecr.us-east-1.amazonaws.com/dc-dashboard-repo:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 8050,
                    "hostPort": 8050,
                    "protocol": "tcp"
                }
            ]
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512"
}